# ─── PTM System Environment Variables ──────────────────────────────────────
# Copy this file to .env.local for local development
# Set these on Vercel Dashboard → Project Settings → Environment Variables

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Admin panel password
ADMIN_PASSWORD=Aesl@1234

# Your deployed URL (no trailing slash)
# On Vercel this is set automatically, but set it explicitly for QR codes
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# ── GOOGLE SHEETS (Required for data storage) ─────────────────────────────────
# Service account email from GCP
GOOGLE_SHEETS_EMAIL=ptm-service@your-project.iam.gserviceaccount.com

# Service account private key (keep quotes, include the full -----BEGIN...END----- block)
GOOGLE_SHEETS_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Google Sheet ID (extracted from sheet URL automatically, but can override)
# SHEET_ID=18U8hwcqpXKuOZyfjy-6LHz3gFnmc4CDq3CS0EUCZHJo
